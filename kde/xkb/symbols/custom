// Custom US layout with Swedish å ä ö accessible via AltGr, in their
// physical Swedish-keyboard positions. Everything else matches plain US.
//
//   AltGr + [  -> å     AltGr + Shift + [  -> Å
//   AltGr + '  -> ä     AltGr + Shift + '  -> Ä
//   AltGr + ;  -> ö     AltGr + Shift + ;  -> Ö

partial alphanumeric_keys
xkb_symbols "us_sv" {
    include "us(basic)"
    name[Group1] = "English (US, Swedish letters on AltGr)";

    key <AD11> { [ bracketleft, braceleft,  aring,      Aring      ] };
    key <AC11> { [ apostrophe,  quotedbl,   adiaeresis, Adiaeresis ] };
    key <AC10> { [ semicolon,   colon,      odiaeresis, Odiaeresis ] };

    include "level3(ralt_switch)"
};
